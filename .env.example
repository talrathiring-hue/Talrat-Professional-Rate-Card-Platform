# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Connection pooling URL (used by Prisma at runtime via PgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (used by Prisma migrations — bypasses PgBouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM_EMAIL="hello@talrat.com"
RESEND_FROM_NAME="talrat"

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
# twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID="ACyour-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
# Sandbox: whatsapp:+14155238886 | Production: whatsapp:+91XXXXXXXXXX
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ─── Upstash Redis (Rate Limiting + Cache) ────────────────────────────────────
# upstash.com → Redis → Create Database → REST API
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Razorpay (Payments) ─────────────────────────────────────────────────────
# razorpay.com → Settings → API Keys (Test or Live)
RAZORPAY_KEY_ID="rzp_test_your-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
# Also expose key ID to client (for Razorpay checkout script)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your-key-id"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="talrat"

# Pro plan price in INR
NEXT_PUBLIC_PRO_PRICE_INR="499"

# ─── Cron Security ────────────────────────────────────────────────────────────
# Set this in Vercel env vars too — protects /api/cron/daily endpoint
CRON_SECRET="your-cron-secret-32-chars"

# ─── Super Admin ──────────────────────────────────────────────────────────────
# Email of the user who will be seeded as ADMIN
SUPER_ADMIN_EMAIL="admin@talrat.com"